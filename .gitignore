# OS / editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
.vscode/
.idea/

# Logs / temporários
*.log
npm-debug.log*

# Dependências (não usamos build; vendor é versionado de propósito)
node_modules/

# Nunca versionar segredos (a publishable key do config.js é pública por design)
.env
.env.*
*.secret

# PDFs de propostas de clientes — pesados e privados; ficam no Supabase Storage,
# não no repositório. (Protótipo local usa site/propostas/*.pdf sem commitar.)
propostas/*.pdf
